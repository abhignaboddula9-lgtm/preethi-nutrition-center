# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use local MongoDB or cloud URI (e.g., MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/preethi_nutrition

# JWT Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=30d

# Initial Admin Credentials (used to seed admin user on startup if not present)
DEFAULT_ADMIN_NAME=Admin Preethi
DEFAULT_ADMIN_EMAIL=admin@preethinutrition.com
DEFAULT_ADMIN_PASSWORD=AdminPass123!
